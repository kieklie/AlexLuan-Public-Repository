# AI Terminology Expert Agent - Environment Variables
# 复制本文件为 .env 并填写真实值。不要将 .env 提交到版本库。

# ============== MiniMax（默认 Agent 对话与 TTS）==============
# https://platform.minimaxi.cn
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ============== DeepSeek（/api/chat 中 model=deepseek 时直连调用）==============
# https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============== Tavily（Function Calling 联网搜索，可选）==============
# https://tavily.com
TAVILY_API_KEY=
# TAVILY_MAX_RESULTS=5

# ============== PostgreSQL（必需：storage 在启动时连接数据库）==============
# postgresql://user:password@localhost:5432/yourdb
DATABASE_URL=

# 连接池大小（可选）
# DB_MIN_POOL_SIZE=1
# DB_MAX_POOL_SIZE=5

# ============== 服务监听 ==============
HOST=0.0.0.0
PORT=8000

# ============== TTS（MiniMax，可选覆盖默认值）==============
# TTS_MODEL=speech-2.8-hd
# TTS_OUTPUT_FORMAT=mp3
